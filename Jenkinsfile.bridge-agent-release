pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
        timeout(time: 90, unit: 'MINUTES')
    }

    parameters {
        string(name: 'BRIDGE_REF', defaultValue: 'main', description: 'Bridge Agent branch containing the release commit')
        string(name: 'BRIDGE_COMMIT', defaultValue: '', description: 'Exact Bridge Agent commit to publish')
        string(name: 'BRIDGE_VERSION', defaultValue: '0.1.104', description: 'Bridge Agent version')
        string(name: 'CLI_VERSION', defaultValue: '0.1.7', description: 'Pinned Baijimu native CLI version')
        booleanParam(name: 'REPAIR_RELEASE', defaultValue: false, description: 'Repair an existing immutable release tag by dispatching the fixed workflow from main')
        booleanParam(name: 'DRY_RUN', defaultValue: true, description: 'Validate and test without publishing refs')
    }

    stages {
        stage('Validate release input') {
            steps {
                sh '''#!/bin/bash
set -euo pipefail
test -n "$BRIDGE_COMMIT"
test "$(git rev-parse HEAD)" = "$BRIDGE_COMMIT"
test "$(node -p 'require("./package.json").version')" = "$BRIDGE_VERSION"
test "$(node -p 'require("./src-tauri/tauri.conf.json").version')" = "$BRIDGE_VERSION"
test "$(sed -n 's/^version = "\\([^"]*\\)"/\\1/p' Cargo.toml | head -1)" = "$BRIDGE_VERSION"
test "$(sed -n 's/^version = "\\([^"]*\\)"/\\1/p' src-tauri/Cargo.toml | head -1)" = "$BRIDGE_VERSION"
test "$(tr -d '[:space:]' < tools/baijimu-cli/VERSION)" = "$CLI_VERSION"
grep -Fq 'tauri_args: --target universal-apple-darwin --bundles app,dmg' .github/workflows/release-bridge-agent.yml
case "$BRIDGE_VERSION" in *[!0-9.]*|'') exit 1 ;; esac
case "$CLI_VERSION" in *[!0-9.]*|'') exit 1 ;; esac
case "$REPAIR_RELEASE" in true|false) ;; *) exit 1 ;; esac
cli_tag_commit="$(git ls-remote https://gitee.com/zxflimit_admin/baijimu-cli-rs.git "refs/tags/v${CLI_VERSION}^{}" | awk 'NR == 1 {print $1}')"
if [ -z "$cli_tag_commit" ]; then
  cli_tag_commit="$(git ls-remote https://gitee.com/zxflimit_admin/baijimu-cli-rs.git "refs/tags/v${CLI_VERSION}" | awk 'NR == 1 {print $1}')"
fi
test -n "$cli_tag_commit"
if [ "$REPAIR_RELEASE" = true ]; then
  release_tag="bridge-agent-v${BRIDGE_VERSION}"
  release_commit="$(git rev-parse -q --verify "refs/tags/${release_tag}^{commit}")"
  test -n "$release_commit"
  test "$release_commit" != "$BRIDGE_COMMIT"
  git merge-base --is-ancestor "$release_commit" "$BRIDGE_COMMIT"
  test "$(git show "${release_commit}:package.json" | node -e 'let data=""; process.stdin.on("data", chunk => data += chunk); process.stdin.on("end", () => process.stdout.write(JSON.parse(data).version))')" = "$BRIDGE_VERSION"
fi
'''
            }
        }

        stage('Test release source') {
            steps {
                sh '''#!/bin/bash
set -euo pipefail
if [ -f "$HOME/.cargo/env" ]; then source "$HOME/.cargo/env"; fi
required_linux_packages=(
  libwebkit2gtk-4.1-dev
  libappindicator3-dev
  librsvg2-dev
  patchelf
)
missing_linux_packages=()
for package in "${required_linux_packages[@]}"; do
  if ! dpkg-query -W -f='${Status}' "$package" 2>/dev/null | grep -Fxq 'install ok installed'; then
    missing_linux_packages+=("$package")
  fi
done
if [ "${#missing_linux_packages[@]}" -ne 0 ]; then
  printf 'Jenkins node is missing Tauri Linux build dependencies: %s\n' "${missing_linux_packages[*]}" >&2
  printf 'Install the packages as the node administrator before releasing.\n' >&2
  exit 1
fi
export CARGO_REGISTRIES_CRATES_IO_PROTOCOL=sparse
export CARGO_HTTP_TIMEOUT=600
export CARGO_NET_RETRY=10
export CARGO_HTTP_MULTIPLEXING=false
export CARGO_TARGET_DIR="$WORKSPACE/.jenkins-cargo-target"
case "$CARGO_TARGET_DIR" in
  "$WORKSPACE"/*) ;;
  *) printf 'Refusing unsafe Cargo target cleanup path: %s\n' "$CARGO_TARGET_DIR" >&2; exit 1 ;;
esac
trap 'rm -rf -- "$CARGO_TARGET_DIR"' EXIT
npm ci
npm run build
cargo test --workspace
cargo test --manifest-path src-tauri/Cargo.toml
'''
            }
        }

        stage('Publish immutable refs') {
            when {
                expression { return !params.DRY_RUN }
            }
            steps {
                withCredentials([
                    usernamePassword(credentialsId: 'bd5fa0ff-2186-41e4-a7aa-97937ef32c02', usernameVariable: 'GITEE_USER', passwordVariable: 'GITEE_TOKEN'),
                    usernamePassword(credentialsId: 'github-momoplan-token', usernameVariable: 'GITHUB_USER', passwordVariable: 'GITHUB_TOKEN')
                ]) {
                    sh '''#!/bin/bash
set -euo pipefail
git config user.name "Baijimu Jenkins"
git config user.email "jenkins@baijimu.com"
set +x
remote="https://gitee.com/zxflimit_admin/bridge-agent.git"
askpass="$WORKSPACE/.bridge-release-git-askpass.sh"
cat > "$askpass" <<'ASKPASS'
#!/bin/sh
case "$1" in
  *Username*) printf '%s\n' "$GIT_AUTH_USER" ;;
  *Password*) printf '%s\n' "$GIT_AUTH_PASSWORD" ;;
  *) exit 1 ;;
esac
ASKPASS
chmod 700 "$askpass"
export GIT_ASKPASS="$askpass"
export GIT_TERMINAL_PROMPT=0
export GIT_AUTH_USER="$GITEE_USER"
export GIT_AUTH_PASSWORD="$GITEE_TOKEN"

current_main="$(git ls-remote "$remote" refs/heads/main | awk 'NR == 1 {print $1}')"
if [ -n "$current_main" ] && ! git merge-base --is-ancestor "$current_main" "$BRIDGE_COMMIT"; then
  echo "refusing non-fast-forward publish to Gitee main" >&2
  exit 1
fi
git push "$remote" "$BRIDGE_COMMIT:refs/heads/main"

tag="bridge-agent-v${BRIDGE_VERSION}"
current_tag="$(git ls-remote "$remote" "refs/tags/$tag" | awk 'NR == 1 {print $1}')"
if [ "$REPAIR_RELEASE" = true ]; then
  test -n "$current_tag"
  test "$current_tag" != "$BRIDGE_COMMIT"
  git merge-base --is-ancestor "$current_tag" "$BRIDGE_COMMIT"
  release_commit="$current_tag"
else
  release_commit="$BRIDGE_COMMIT"
  if [ -n "$current_tag" ]; then
    test "$current_tag" = "$release_commit"
  else
    git push "$remote" "$release_commit:refs/tags/$tag"
  fi
fi
rm -f "$askpass"

tools/release/publish-github-ref.sh momoplan/bridge-agent branch main "$BRIDGE_COMMIT"
tools/release/publish-github-ref.sh momoplan/bridge-agent tag "$tag" "$release_commit"
if [ "$REPAIR_RELEASE" = true ]; then
  dispatch_payload="$(jq -nc --arg ref main --arg tag "$tag" '{ref: $ref, inputs: {release_tag: $tag}}')"
  dispatch_status="$(curl -sS -o /dev/null -w '%{http_code}' \
    -H "Authorization: Bearer ${GITHUB_TOKEN}" \
    -H 'Accept: application/vnd.github+json' \
    -H 'X-GitHub-Api-Version: 2022-11-28' \
    -X POST \
    -d "$dispatch_payload" \
    'https://api.github.com/repos/momoplan/bridge-agent/actions/workflows/release-bridge-agent.yml/dispatches')"
  test "$dispatch_status" = 204
  echo "dispatched repair workflow for $tag from main at $BRIDGE_COMMIT"
fi
set -x
'''
                }
            }
        }

        stage('Wait for signed desktop release') {
            when {
                expression { return !params.DRY_RUN }
            }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'github-momoplan-token',
                    usernameVariable: 'GITHUB_USER',
                    passwordVariable: 'GITHUB_TOKEN'
                )]) {
                    sh '''#!/bin/bash
set -euo pipefail
if [ "$REPAIR_RELEASE" = true ]; then
  tools/release/wait-github-workflow.sh momoplan/bridge-agent release-bridge-agent.yml "bridge-agent-v${BRIDGE_VERSION}" "$BRIDGE_COMMIT" workflow_dispatch main
else
  tools/release/wait-github-workflow.sh momoplan/bridge-agent release-bridge-agent.yml "bridge-agent-v${BRIDGE_VERSION}" "$BRIDGE_COMMIT"
fi
'''
                }
            }
        }

        stage('Verify published desktop and updater') {
            when {
                expression { return !params.DRY_RUN }
            }
            steps {
                sh '''#!/bin/bash
set -euo pipefail
release="$(curl -fsS "https://api.github.com/repos/momoplan/bridge-agent/releases/tags/bridge-agent-v${BRIDGE_VERSION}")"
printf '%s' "$release" | jq -e --arg version "$BRIDGE_VERSION" '
  .draft == false and
  ([.assets[].name] | index("Baijimu_" + $version + "_universal.dmg") != null) and
  ([.assets[].name] | index("Baijimu_" + $version + "_universal.app.tar.gz") != null) and
  ([.assets[].name] | index("Baijimu_" + $version + "_universal.app.tar.gz.sig") != null) and
  ([.assets[].name] | index("Baijimu_" + $version + "_x64_en-US.msi") != null) and
  ([.assets[].name] | index("Baijimu_" + $version + "_x64_en-US.msi.sig") != null) and
  ([.assets[].name] | index("Baijimu_" + $version + "_amd64.AppImage") != null) and
  ([.assets[].name] | index("Baijimu_" + $version + "_amd64.AppImage.sig") != null) and
  ([.assets[].name] | index("Baijimu_" + $version + "_amd64.deb") != null)'

latest="$(curl -fsS 'https://updates.baijimu.com/api/bridge-agent/releases/latest')"
printf '%s' "$latest" | jq -e --arg version "$BRIDGE_VERSION" '
  ((.data // .).version // (.data // .).latestVersion // "") == $version and
  any((.data // .).assets[]; (.name | endswith(".app.tar.gz")) and (((.signature // "") | length) > 0))'

tauri_update="$(curl -fsS "https://updates.baijimu.com/api/bridge-agent/releases/latest/tauri?target=darwin&arch=aarch64&currentVersion=0.0.0")"
printf '%s' "$tauri_update" | jq -e --arg version "$BRIDGE_VERSION" '
  .version == $version and
  (.url | endswith(".app.tar.gz")) and
  (.signature | length) > 0'
'''
            }
        }
    }
}
