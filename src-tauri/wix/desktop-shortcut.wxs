<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Fragment>
    <DirectoryRef Id="TARGETDIR">
      <Directory Id="DesktopFolder" Name="Desktop" />
    </DirectoryRef>
  </Fragment>

  <Fragment>
    <DirectoryRef Id="DesktopFolder">
      <Component Id="BaijimuDesktopShortcut" Guid="*">
        <Shortcut
          Id="BaijimuDesktopShortcut"
          Name="百积木"
          Description="百积木本地连接客户端"
          Target="[INSTALLDIR]bridge-agent-desktop.exe"
          WorkingDirectory="INSTALLDIR" />
        <RegistryValue
          Root="HKCU"
          Key="Software\Baijimu\BridgeAgent"
          Name="desktopShortcut"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>
    </DirectoryRef>
  </Fragment>
</Wix>
