{
  "productName": "Baijimu",
  "bundle": {
    "windows": {
      "signCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/sign-windows-artifact.ps1 %1",
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "wix": {
        "fragmentPaths": [
          "wix/bridge-agent-service.wxs"
        ],
        "componentRefs": [
          "BridgeAgentServiceComponent",
          "BridgeAgentDataDirectoryComponent"
        ]
      },
      "nsis": {
        "installerHooks": "nsis/desktop-shortcut.nsh"
      }
    }
  }
}
