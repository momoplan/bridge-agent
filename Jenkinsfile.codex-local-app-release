pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
        timeout(time: 100, unit: 'MINUTES')
    }

    parameters {
        string(name: 'BRIDGE_REF', defaultValue: 'codex/codex-management-app', description: 'Bridge Agent branch containing the release')
        string(name: 'BRIDGE_COMMIT', defaultValue: '', description: 'Exact Bridge Agent commit to publish')
        string(name: 'BRIDGE_VERSION', defaultValue: '0.1.104', description: 'Bridge Agent version')
        string(name: 'CONNECTOR_REF', defaultValue: 'codex/local-app-embedded-ui', description: 'Codex local app source branch')
        string(name: 'CONNECTOR_COMMIT', defaultValue: '', description: 'Exact Codex local app commit to publish')
        string(name: 'CONNECTOR_VERSION', defaultValue: '0.5.0', description: 'Codex local app version')
        booleanParam(name: 'DRY_RUN', defaultValue: true, description: 'Validate and test without publishing refs or market data')
    }

    stages {
        stage('Validate release input') {
            steps {
                sh '''#!/bin/bash
set -euo pipefail
test -n "$BRIDGE_COMMIT"
test -n "$CONNECTOR_COMMIT"
test "$(git rev-parse "${BRIDGE_COMMIT}^{commit}")" = "$BRIDGE_COMMIT"
git merge-base --is-ancestor "$BRIDGE_COMMIT" HEAD
test "$(git show "${BRIDGE_COMMIT}:package.json" | jq -r '.version')" = "$BRIDGE_VERSION"
test "$(git show "${BRIDGE_COMMIT}:src-tauri/tauri.conf.json" | jq -r '.version')" = "$BRIDGE_VERSION"
case "$BRIDGE_VERSION" in *[!0-9.]*|'') exit 1 ;; esac
case "$CONNECTOR_VERSION" in *[!0-9.]*|'') exit 1 ;; esac
'''
                dir('connector-src') {
                    deleteDir()
                    checkout([
                        $class: 'GitSCM',
                        branches: [[name: "*/${params.CONNECTOR_REF}"]],
                        doGenerateSubmoduleConfigurations: false,
                        extensions: [[$class: 'CloneOption', depth: 1, noTags: false, shallow: true]],
                        submoduleCfg: [],
                        userRemoteConfigs: [[
                            credentialsId: 'bd5fa0ff-2186-41e4-a7aa-97937ef32c02',
                            url: 'https://gitee.com/zxflimit_admin/baijimu-connector-codex.git'
                        ]]
                    ])
                }
                sh '''#!/bin/bash
set -euo pipefail
test "$(git -C connector-src rev-parse HEAD)" = "$CONNECTOR_COMMIT"
test "$(sed -n 's/^version = "\\([^"]*\\)"/\\1/p' connector-src/Cargo.toml | head -1)" = "$CONNECTOR_VERSION"
test "$(node -p 'require("./connector-src/connector.json").version')" = "$CONNECTOR_VERSION"
'''
            }
        }

        stage('Test release source') {
            steps {
                sh '''#!/bin/bash
set -euo pipefail
git worktree remove --force release-src >/dev/null 2>&1 || true
git worktree prune
git worktree add --detach release-src "$BRIDGE_COMMIT"
'''
                dir('release-src') {
                    sh '''#!/bin/bash
set -euo pipefail
if [ -f "$HOME/.cargo/env" ]; then source "$HOME/.cargo/env"; fi
cargo test --workspace
npm ci
npm run build
'''
                }
                sh '''#!/bin/bash
set -euo pipefail
if [ -f "$HOME/.cargo/env" ]; then source "$HOME/.cargo/env"; fi
cargo test --manifest-path connector-src/Cargo.toml
'''
            }
        }

        stage('Publish source refs') {
            when {
                expression { return !params.DRY_RUN }
            }
            steps {
                withCredentials([
                    usernamePassword(credentialsId: 'bd5fa0ff-2186-41e4-a7aa-97937ef32c02', usernameVariable: 'GITEE_USER', passwordVariable: 'GITEE_TOKEN'),
                    usernamePassword(credentialsId: 'github-momoplan-token', usernameVariable: 'GITHUB_USER', passwordVariable: 'GITHUB_TOKEN')
                ]) {
                    sh '''#!/bin/bash
set -euo pipefail
git config user.name "Baijimu Jenkins"
git config user.email "jenkins@baijimu.com"
set +x
gitee_bridge="https://gitee.com/zxflimit_admin/bridge-agent.git"
gitee_connector="https://gitee.com/zxflimit_admin/baijimu-connector-codex.git"
askpass="$WORKSPACE/.release-git-askpass.sh"
cat > "$askpass" <<'ASKPASS'
#!/bin/sh
case "$1" in
  *Username*) printf '%s\n' "$GIT_AUTH_USER" ;;
  *Password*) printf '%s\n' "$GIT_AUTH_PASSWORD" ;;
  *) exit 1 ;;
esac
ASKPASS
chmod 700 "$askpass"
export GIT_ASKPASS="$askpass"
export GIT_TERMINAL_PROMPT=0

publish_branch() {
  remote="$1"
  commit="$2"
  branch="$3"
  current="$(git ls-remote "$remote" "refs/heads/$branch" | awk 'NR == 1 {print $1}')"
  if [ -n "$current" ] && ! git merge-base --is-ancestor "$current" "$commit"; then
    echo "refusing non-fast-forward publish to $branch" >&2
    exit 1
  fi
  git push "$remote" "$commit:refs/heads/$branch"
}

publish_tag() {
  remote="$1"
  commit="$2"
  tag="$3"
  current="$(git ls-remote "$remote" "refs/tags/$tag" | awk 'NR == 1 {print $1}')"
  if [ -n "$current" ]; then
    if [ "$current" = "$commit" ]; then
      return
    fi
    github_status="$(curl -sS --connect-timeout 10 --max-time 30 -o /dev/null -w '%{http_code}' \
      -H "Authorization: Bearer ${GITHUB_TOKEN}" \
      -H 'Accept: application/vnd.github+json' \
      -H 'X-GitHub-Api-Version: 2022-11-28' \
      "https://api.github.com/repos/momoplan/bridge-agent/git/ref/tags/${tag}")"
    if git merge-base --is-ancestor "$current" "$commit" && [ "$github_status" = 404 ]; then
      echo "repairing partial Gitee tag $tag from $current to $commit"
      git push --force "$remote" "$commit:refs/tags/$tag"
      return
    fi
    echo "tag $tag already points to $current, expected $commit" >&2
    exit 1
  fi
  git push "$remote" "$commit:refs/tags/$tag"
}

git -C connector-src config user.name "Baijimu Jenkins"
git -C connector-src config user.email "jenkins@baijimu.com"
export GIT_AUTH_USER="$GITEE_USER"
export GIT_AUTH_PASSWORD="$GITEE_TOKEN"
current="$(git ls-remote "$gitee_connector" "refs/tags/v${CONNECTOR_VERSION}" | awk 'NR == 1 {print $1}')"
if [ -n "$current" ]; then
  test "$current" = "$CONNECTOR_COMMIT"
else
  git -C connector-src push "$gitee_connector" "$CONNECTOR_COMMIT:refs/tags/v${CONNECTOR_VERSION}"
fi

publish_branch "$gitee_bridge" "$BRIDGE_COMMIT" main
publish_tag "$gitee_bridge" "$BRIDGE_COMMIT" "codex-local-app-v${CONNECTOR_VERSION}"

rm -f "$askpass"
tools/release/publish-github-ref.sh momoplan/bridge-agent branch main "$BRIDGE_COMMIT"
tools/release/publish-github-ref.sh momoplan/bridge-agent tag "codex-local-app-v${CONNECTOR_VERSION}" "$BRIDGE_COMMIT"
set -x
'''
                }
            }
        }

        stage('Wait for signed Codex local app release') {
            when {
                expression { return !params.DRY_RUN }
            }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'github-momoplan-token',
                    usernameVariable: 'GITHUB_USER',
                    passwordVariable: 'GITHUB_TOKEN'
                )]) {
                    sh '''#!/bin/bash
set -euo pipefail
tools/release/wait-github-workflow.sh momoplan/bridge-agent release-codex-local-app.yml "codex-local-app-v${CONNECTOR_VERSION}" "$BRIDGE_COMMIT"
'''
                }
            }
        }

        stage('Publish local app market') {
            when {
                expression { return !params.DRY_RUN }
            }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'github-momoplan-token',
                    usernameVariable: 'GITHUB_USER',
                    passwordVariable: 'GITHUB_TOKEN'
                )]) {
                    sh 'tools/release/publish-codex-local-app-market.sh "$CONNECTOR_VERSION"'
                }
            }
        }

        stage('Publish Bridge Agent release ref') {
            when {
                expression { return !params.DRY_RUN }
            }
            steps {
                withCredentials([
                    usernamePassword(credentialsId: 'bd5fa0ff-2186-41e4-a7aa-97937ef32c02', usernameVariable: 'GITEE_USER', passwordVariable: 'GITEE_TOKEN'),
                    usernamePassword(credentialsId: 'github-momoplan-token', usernameVariable: 'GITHUB_USER', passwordVariable: 'GITHUB_TOKEN')
                ]) {
                    sh '''#!/bin/bash
set -euo pipefail
set +x
remote="https://gitee.com/zxflimit_admin/bridge-agent.git"
askpass="$WORKSPACE/.bridge-release-git-askpass.sh"
cat > "$askpass" <<'ASKPASS'
#!/bin/sh
case "$1" in
  *Username*) printf '%s\n' "$GITEE_USER" ;;
  *Password*) printf '%s\n' "$GITEE_TOKEN" ;;
  *) exit 1 ;;
esac
ASKPASS
chmod 700 "$askpass"
export GIT_ASKPASS="$askpass"
export GIT_TERMINAL_PROMPT=0
tag="bridge-agent-v${BRIDGE_VERSION}"
current="$(git ls-remote "$remote" "refs/tags/$tag" | awk 'NR == 1 {print $1}')"
if [ -n "$current" ]; then
  test "$current" = "$BRIDGE_COMMIT"
else
  git push "$remote" "$BRIDGE_COMMIT:refs/tags/$tag"
fi
rm -f "$askpass"
tools/release/publish-github-ref.sh momoplan/bridge-agent tag "$tag" "$BRIDGE_COMMIT"
set -x
'''
                }
            }
        }

        stage('Wait for signed Bridge Agent release') {
            when {
                expression { return !params.DRY_RUN }
            }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'github-momoplan-token',
                    usernameVariable: 'GITHUB_USER',
                    passwordVariable: 'GITHUB_TOKEN'
                )]) {
                    sh 'tools/release/wait-github-workflow.sh momoplan/bridge-agent release-bridge-agent.yml "bridge-agent-v${BRIDGE_VERSION}" "$BRIDGE_COMMIT"'
                }
            }
        }

        stage('Verify published releases') {
            when {
                expression { return !params.DRY_RUN }
            }
            steps {
                sh '''#!/bin/bash
set -euo pipefail
curl -fsS "https://api.github.com/repos/momoplan/bridge-agent/releases/tags/bridge-agent-v${BRIDGE_VERSION}" \
  | jq -e --arg version "$BRIDGE_VERSION" '
      .draft == false and
      ([.assets[].name] | index("Baijimu_" + $version + "_universal.dmg") != null) and
      ([.assets[].name] | index("Baijimu_" + $version + "_x64_en-US.msi") != null) and
      ([.assets[].name] | index("Baijimu_" + $version + "_amd64.AppImage") != null) and
      ([.assets[].name] | index("Baijimu_" + $version + "_amd64.deb") != null)'
curl -fsS "https://api.github.com/repos/momoplan/bridge-agent/releases/tags/codex-local-app-v${CONNECTOR_VERSION}" \
  | jq -e --arg version "$CONNECTOR_VERSION" '
      .draft == false and
      ([.assets[].name] | index("baijimu-codex-local-app-" + $version + "-macos-universal.zip") != null) and
      ([.assets[].name] | index("baijimu-codex-local-app-" + $version + "-windows-x64.zip") != null) and
      ([.assets[].name] | index("baijimu-codex-local-app-" + $version + "-linux-x64.zip") != null)'
curl -fsS "https://www.baijimu.com/lowcode3/api/local-app-market/apps/codex?platform=macos&arch=aarch64" \
  | jq -e --arg version "$CONNECTOR_VERSION" '(.data // .).latestVersion.version == $version'
'''
            }
        }
    }

    post {
        always {
            sh 'git worktree remove --force release-src >/dev/null 2>&1 || true; git worktree prune'
            archiveArtifacts artifacts: 'codex-market-before-*.tsv', allowEmptyArchive: true
        }
    }
}
